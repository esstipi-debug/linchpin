# Linchpin environment — copy to `.env` and fill in as needed.
# Everything here is OPTIONAL: the engine, web app and tests all run with zero
# secrets. Missing keys degrade gracefully to the rules-based path; they never crash.
# `.env` is git-ignored (see .gitignore) — never commit real keys.

# --- Application -------------------------------------------------------------
# Enables Claude-assisted brief parsing and narrative generation in the agent
# (scm_agent/llm.py). Without it, the orchestrator uses the rules-based fallback.
# Requires the optional extra:  pip install -e ".[llm]"
ANTHROPIC_API_KEY=

# --- Tooling (not used at runtime) ------------------------------------------
# Only used by the external `graphify` CLI when (re)building the code graph
# (graphify-out/) with the Kimi backend. Not read by the app, engine, or tests.
MOONSHOT_API_KEY=
