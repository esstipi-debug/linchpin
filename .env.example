# Linchpin environment — copy to `.env` and fill in as needed.
# Everything here is OPTIONAL: the engine, web app and tests all run with zero
# secrets. Missing keys degrade gracefully to the rules-based path; they never crash.
# `.env` is git-ignored (see .gitignore) — never commit real keys.

# --- Application -------------------------------------------------------------
# Enables Claude-assisted brief parsing and narrative generation in the agent
# (scm_agent/llm.py). Without it, the orchestrator uses the rules-based fallback.
# Requires the optional extra:  pip install -e ".[llm]"
ANTHROPIC_API_KEY=

# --- Web app hardening (opt-in; see SECURITY.md) -----------------------------
# All default to OFF so local/dev use is unchanged. Set these before a public deploy.
# Require a matching `X-API-Key` header on POST /api/jobs (unset = open):
LINCHPIN_API_KEY=
# Sliding-window rate limit per client IP; 0 disables. Window is in seconds:
LINCHPIN_RATE_LIMIT=0
LINCHPIN_RATE_WINDOW=60
# Comma-separated CORS allowlist (unset = same-origin only):
LINCHPIN_CORS_ORIGINS=
# Signs writeback Approvals (src/writeback.py) so one can't be forged by
# constructing it directly instead of calling approve() (unset = unsigned):
LINCHPIN_APPROVAL_SECRET=
# Path to the MCP per-client key store (src/mcp_keys.py). Defaults to
# data/mcp_keys.sqlite3 — on a platform with an ephemeral filesystem (e.g. a
# Railway deploy without a mounted Volume), point this at your persistent disk:
LINCHPIN_MCP_KEYS_PATH=

# --- Production guard & logging (opt-in; see docs/DEPLOYMENT.md) --------------
# "production" makes the app warn loudly at boot if API key / rate limit / approval
# secret are unset:
LINCHPIN_ENV=development
# Set to 1 to REFUSE booting an unsecured production deploy (else it only warns):
LINCHPIN_REQUIRE_SECURE=
# Structured (JSON) access logs + level for the linchpin.access logger:
LINCHPIN_LOG_JSON=
LINCHPIN_LOG_LEVEL=INFO

# --- Odoo ERP connector (optional; src/connectors/odoo.py) -------------------
# Set all four to read inventory / sales from a live Odoo over XML-RPC and stage
# restocks back as reorder rules. Unset -> the connector still runs against an
# in-memory stand-in (examples/run_odoo.py), so no credentials are required to try it.
# API key: Odoo 14+  Settings -> Account Security -> Developer API Keys.
ODOO_URL=
ODOO_DB=
ODOO_USERNAME=
ODOO_API_KEY=

# --- Tooling (not used at runtime) ------------------------------------------
# Only used by the external `graphify` CLI when (re)building the code graph
# (graphify-out/) with the Kimi backend. Not read by the app, engine, or tests.
MOONSHOT_API_KEY=
