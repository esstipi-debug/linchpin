# OS Files
.DS_Store
Thumbs.db
*.swp
*.swo

# Office Files (Temp)
~$*.xlsx
~$*.xlsm
*.tmp

# IDE
.vscode/
.idea/
*.pyc
__pycache__/

# Node (if adding web components)
node_modules/
.env
.env.local

# Python
*.egg-info/
dist/
build/
venv/
.pytest_cache/
.ruff_cache/
.coverage
.coverage.*
htmlcov/

# graphify knowledge-graph output (generated)
graphify-out/
knowledge/scm-books-rebuild/
knowledge/scm-books/graph.json.bak
knowledge/scm-books/graph.cluster.bak

# generated client deliverables
deliverables/

# large external datasets (Kaggle / M5 etc. — fetched locally, not versioned)
data/kaggle/

# local SQLite state (writeback audit ledger, MCP client keys) - never versioned;
# the latter would otherwise leak paying-client names into git history.
data/*.sqlite3

# src/state system-state snapshot store (SQLite index + parquet/CSV history) -
# regenerable from live system data, never versioned.
data/state/

# src/pricing_intel PriceLedger (SQLite index + parquet/CSV competitor-price
# history) - regenerable from live acquisition data, never versioned.
data/pricing_intel/

# per-client parameter profiles (src/client_profile.py) - real client cost/capacity
# numbers, never versioned. UNLIKE the rest of this file, this is NOT regenerable —
# back it up separately (see CLAUDE.md gotchas).
clients/

# Excel writeback artifacts: per-commit byte-exact backups of client files and the
# monitor's run snapshots - real client inventory data, never versioned.
*.linchpin-backup*
.linchpin-monitor/

# Misc — version the shared hook + settings, ignore personal/local overrides
.claude/*
!.claude/settings.json
!.claude/hooks/
.claude/settings.local.json
.secrets/
*.log
output/

# orchestrator job outputs
webapp/_jobs_output/
.gstack/

# captured demo leads (PII — never versioned)
webapp/_leads/
# local code-intelligence indexes (codegraph / serena MCP servers)
.codegraph/
.serena/
