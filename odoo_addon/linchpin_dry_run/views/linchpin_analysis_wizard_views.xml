<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="linchpin_analysis_wizard_view_form" model="ir.ui.view">
        <field name="name">linchpin.analysis.wizard.view.form</field>
        <field name="model">linchpin.analysis.wizard</field>
        <field name="arch" type="xml">
            <form string="Linchpin Inventory Analysis">
                <field name="state" invisible="1"/>
                <group invisible="state != 'draft'">
                    <field name="history_days"/>
                    <p class="text-muted">
                        For each confirmed sale in the window above, this sends the product's
                        SKU, order date, quantity, unit cost, your primary supplier's lead time,
                        and your company name to Linchpin's cloud service for analysis. No
                        stock/on-hand quantities are read or sent. Nothing is written back to
                        Odoo - this is a read-only dry run.
                    </p>
                </group>
                <group invisible="state != 'done'">
                    <field name="result_summary" string="Summary"/>
                    <field name="result_markdown" string="Full report" widget="text"/>
                </group>
                <footer>
                    <button name="action_run_analysis" string="Run Analysis" type="object"
                            class="btn-primary" invisible="state != 'draft'"/>
                    <button string="Close" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="linchpin_analysis_wizard_action" model="ir.actions.act_window">
        <field name="name">Linchpin Inventory Analysis</field>
        <field name="res_model">linchpin.analysis.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>
</odoo>
